# AidFlow Pro — Environment Configuration
# Copy this file to `.env.local` and fill in your values.
# All variables prefixed with VITE_ are exposed to the browser.

# Ollama endpoint serving Gemma 4 E4B (default: localhost:11434)
# Field workers can override this in Settings if Ollama runs on a LAN host.
VITE_OLLAMA_BASE_URL=http://localhost:11434

# Ollama model tag (the user has Gemma 4 downloaded locally)
# Check available tags with:  ollama list
VITE_OLLAMA_MODEL=gemma4:e4b

# Local embedding model used for the RAG pipeline
VITE_OLLAMA_EMBED_MODEL=nomic-embed-text

# Default UI language: en | ar | fr | es
VITE_DEFAULT_LANG=en

# App display name (shown in PWA manifest and header)
VITE_APP_NAME=AidFlow Pro
